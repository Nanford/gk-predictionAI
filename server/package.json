{
  "name": "gaokao-ai-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:bootstrap": "tsx scripts/bootstrap-db.ts",
    "import:universities": "tsx scripts/import-universities.ts",
    "import:score-rank": "tsx scripts/import-score-rank.ts",
    "import:admission-history": "tsx scripts/import-admission-history.ts",
    "seed:demo": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@fastify/cors": "11.2.0",
    "@prisma/adapter-mariadb": "7.8.0",
    "@prisma/client": "7.8.0",
    "csv-parse": "6.2.1",
    "dotenv": "17.4.2",
    "fastify": "5.8.5",
    "mariadb": "3.4.5",
    "mysql2": "3.22.4"
  },
  "devDependencies": {
    "@types/node": "24.10.1",
    "prisma": "7.8.0",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.8"
  }
}
